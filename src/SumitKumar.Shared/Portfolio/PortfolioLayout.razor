@using Microsoft.Extensions.Options
@inherits LayoutComponentBase
@inject IOptions<PortfolioOptions> Options

<header id="header" class="header d-flex flex-column justify-content-center">

    <i class="header-toggle d-xl-none bi bi-list"></i>

    <nav id="navmenu" class="navmenu">
        <ul>
            <li><a href="#hero" class="active"><i class="bi bi-house navicon"></i><span>Home</span></a></li>
            <li><a href="#about"><i class="bi bi-person navicon"></i><span>About</span></a></li>
            <li><a href="#resume"><i class="bi bi-file-earmark-text navicon"></i><span>Resume</span></a></li>
            <li><a href="#portfolio"><i class="bi bi-images navicon"></i><span>Portfolio</span></a></li>
            <li><a href="#services"><i class="bi bi-hdd-stack navicon"></i><span>Services</span></a></li>
            <li><a href="blog"><i class="bi bi-journal-richtext navicon"></i><span>Blog</span></a></li>
            <li><a href="#contact"><i class="bi bi-envelope navicon"></i><span>Contact</span></a></li>
        </ul>
    </nav>

</header>

<main class="main">
    @Body
</main>

<footer id="footer" class="footer position-relative light-background">
    <div class="container">
        <h3 class="sitename">@Profile.FullName</h3>
        <p>@Options.Value.About.Tagline</p>
        <div class="social-links d-flex justify-content-center">
            @foreach (var s in Options.Value.Social)
            {
                <a href="@s.Url" target="_blank" rel="noopener"><i class="bi @s.Icon"></i></a>
            }
        </div>
        <div class="container">
            <div class="copyright">
                <span>Copyright</span> <strong class="px-1 sitename">@Profile.FullName</strong> <span>All Rights Reserved</span>
            </div>
            <div class="credits">
                Designed by <a href="https://bootstrapmade.com/">BootstrapMade</a>
            </div>
        </div>
    </div>
</footer>

<a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

@code {
    private ProfileSection Profile => Options.Value.Profile;
}
