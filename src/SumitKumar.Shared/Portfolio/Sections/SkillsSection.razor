@using Microsoft.Extensions.Options
@inject IOptions<PortfolioOptions> Options

@if (Options.Value.Skills.Count > 0)
{
    <!-- Skills Section -->
    <section id="skills" class="skills section">

        <!-- Section Title -->
        <div class="container section-title" data-aos="fade-up">
            <h2>Skills</h2>
            <p>@(string.IsNullOrWhiteSpace(SkillsTagline) ? "Technologies and capabilities I work with every day" : SkillsTagline)</p>
        </div><!-- End Section Title -->

        <div class="container" data-aos="fade-up" data-aos-delay="100">

            <div class="row skills-content skills-animation">

                @{
                    var skills = Options.Value.Skills;
                    var half = (skills.Count + 1) / 2;
                    var left = skills.Take(half).ToList();
                    var right = skills.Skip(half).ToList();
                }

                <div class="col-lg-6">
                    @foreach (var skill in left)
                    {
                        <div class="progress">
                            <span class="skill"><span>@skill.Name</span> <i class="val">@skill.Percent%</i></span>
                            <div class="progress-bar-wrap">
                                <div class="progress-bar" role="progressbar" aria-valuenow="@skill.Percent" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                    }
                </div>

                <div class="col-lg-6">
                    @foreach (var skill in right)
                    {
                        <div class="progress">
                            <span class="skill"><span>@skill.Name</span> <i class="val">@skill.Percent%</i></span>
                            <div class="progress-bar-wrap">
                                <div class="progress-bar" role="progressbar" aria-valuenow="@skill.Percent" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                    }
                </div>

            </div>

        </div>

    </section><!-- /Skills Section -->
}

@code {
    [Parameter] public string? SkillsTagline { get; set; }
}
