@using Microsoft.Extensions.Options
@inject IOptions<PortfolioOptions> Options

<!-- About Section -->
<section id="about" class="about section">

    <!-- Section Title -->
    <div class="container section-title" data-aos="fade-up">
        <h2>About</h2>
        <p>@Options.Value.About.Tagline</p>
    </div><!-- End Section Title -->

    <div class="container" data-aos="fade-up" data-aos-delay="100">

        <div class="row gy-4 justify-content-center">
            <div class="col-lg-4">
                <img src="@Options.Value.Profile.AvatarUrl" class="img-fluid" alt="@Options.Value.Profile.FullName" />
            </div>
            <div class="col-lg-8 content">
                <h2>@Options.Value.Profile.Headline</h2>
                <p class="fst-italic py-3">
                    @Options.Value.About.Description
                </p>
                <div class="row">
                    @{
                        var facts = Options.Value.About.Facts;
                        var half = (facts.Count + 1) / 2;
                        var left = facts.Take(half).ToList();
                        var right = facts.Skip(half).ToList();
                    }
                    <div class="col-lg-6">
                        <ul>
                            @foreach (var f in left)
                            {
                                <li><i class="bi bi-chevron-right"></i> <strong>@f.Label:</strong> <span>@f.Value</span></li>
                            }
                        </ul>
                    </div>
                    <div class="col-lg-6">
                        <ul>
                            @foreach (var f in right)
                            {
                                <li><i class="bi bi-chevron-right"></i> <strong>@f.Label:</strong> <span>@f.Value</span></li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>

    </div>

</section><!-- /About Section -->
