@using Microsoft.Extensions.Options
@inject IOptions<PortfolioOptions> Options

<!-- Portfolio Section -->
<section id="portfolio" class="portfolio section">

    <!-- Section Title -->
    <div class="container section-title" data-aos="fade-up">
        <h2>Portfolio</h2>
        <p>A selection of recent projects and platforms I've helped design, architect or deliver.</p>
    </div><!-- End Section Title -->

    <div class="container">

        <div class="isotope-layout" data-default-filter="*" data-layout="masonry" data-sort="original-order">

            <ul class="portfolio-filters isotope-filters" data-aos="fade-up" data-aos-delay="100">
                <li data-filter="*" class="filter-active">All</li>
                @foreach (var c in Categories)
                {
                    <li data-filter=".filter-@CategorySlug(c)">@c</li>
                }
            </ul><!-- End Portfolio Filters -->

            <div class="row gy-4 isotope-container" data-aos="fade-up" data-aos-delay="200">

                @foreach (var p in Options.Value.Portfolio)
                {
                    var slug = CategorySlug(p.Category);
                    <div class="col-lg-4 col-md-6 portfolio-item isotope-item filter-@slug">
                        <img src="@p.ImageUrl" class="img-fluid" alt="@p.Title" />
                        <div class="portfolio-info">
                            <h4>@p.Title</h4>
                            <p>@p.Category</p>
                            <a href="@p.ImageUrl" title="@p.Title" data-gallery="portfolio-gallery-@slug" class="glightbox preview-link"><i class="bi bi-zoom-in"></i></a>
                            @if (!string.IsNullOrWhiteSpace(p.Url) && p.Url != "#")
                            {
                                <a href="@p.Url" title="More Details" class="details-link" target="_blank" rel="noopener"><i class="bi bi-link-45deg"></i></a>
                            }
                        </div>
                    </div><!-- End Portfolio Item -->
                }

            </div><!-- End Portfolio Container -->

        </div>

    </div>

</section><!-- /Portfolio Section -->

@code {
    private IEnumerable<string> Categories => Options.Value.Portfolio
        .Select(p => p.Category)
        .Where(c => !string.IsNullOrWhiteSpace(c))
        .Distinct(StringComparer.OrdinalIgnoreCase);

    private static string CategorySlug(string? category) => string.IsNullOrWhiteSpace(category)
        ? "uncategorized"
        : new string(category.ToLowerInvariant().Select(ch => char.IsLetterOrDigit(ch) ? ch : '-').ToArray()).Trim('-');
}
